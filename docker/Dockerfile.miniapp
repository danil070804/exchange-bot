FROM node:20-alpine AS build

WORKDIR /app
COPY apps/miniapp/package*.json ./
RUN npm install

COPY apps/miniapp ./
# If host node_modules is copied from Windows, it can break Linux executables (e.g. tsc permission denied).
RUN rm -rf node_modules && npm install
RUN npm run build

FROM node:20-alpine
WORKDIR /app
RUN npm install -g serve
COPY --from=build /app/dist ./dist

ENV PORT=4173
CMD ["sh", "-c", "serve -s dist -l ${PORT}"]